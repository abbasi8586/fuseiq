# Environment Variables Template
# Copy to .env.local and fill in your Supabase values

# Supabase (Required for auth & database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App Config
NEXT_PUBLIC_APP_URL=https://fuseiq.vercel.app
NEXT_PUBLIC_APP_NAME=FuseIQ

# Provider Rate Cards (for cost calculation)
OPENAI_RATE_INPUT=0.00001
OPENAI_RATE_OUTPUT=0.00003
ANTHROPIC_RATE_INPUT=0.000008
ANTHROPIC_RATE_OUTPUT=0.000024
KIMI_RATE_INPUT=0.000005
KIMI_RATE_OUTPUT=0.000015
GOOGLE_RATE_INPUT=0.0000035
GOOGLE_RATE_OUTPUT=0.0000105

# Optional (Phase 3)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# RESEND_API_KEY=
# SENTRY_DSN=
